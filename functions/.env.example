# Nadlan / Agent Platform — non-secret config params
# Copy to functions/.env (gitignored) and fill in real values.
# Firebase Functions v2 loads these automatically via defineString().
#
# Secrets (GREENAPI_INSTANCE, GREENAPI_TOKEN, NADLAN_JWT_SECRET, DEMO_SECRET)
# do NOT go here — they're defineSecret() params, managed via Secret Manager
# in prod and functions/.secret.local for the emulator (existing convention).

# Base URL the generated property pages are served from.
# call4li-nadlan.web.app until nadlan.call4li.com DNS is live.
PAGE_BASE_URL=https://call4li-nadlan.web.app

# n8n webhook URLs (from N8N_WEBHOOK_URL base + workflow path)
N8N_WW1_WEBHOOK_URL=https://n8n.srv1173890.hstgr.cloud/webhook/dashboard-create
N8N_PIPELINE_WEBHOOK_URL=https://n8n.srv1173890.hstgr.cloud/webhook/property-page-builder
N8N_LEAD_WEBHOOK_URL=https://n8n.srv1173890.hstgr.cloud/webhook/lead-trigger

# WhatsApp number that receives pipeline error alerts (972 format, no +)
ADMIN_PHONE=
