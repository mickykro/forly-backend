# Copy to server/.env and fill in. The server auto-loads this file on startup.
#   cp server/.env.example server/.env

# Public base URL of THIS server (no trailing slash). Baked into the photo
# URLs sent to n8n, so Seedance/Vision Tagger must be able to reach it.
# Local test with a tunnel:  cloudflared tunnel --url http://localhost:8787
# then paste the printed https URL here. On the VPS, use the public host.
BASE_URL=http://127.0.0.1:8787

# Local-dev only: proxy uploads to the production host so local test images get
# the SAME (production) URL and are fetchable by the real pipeline. The browser
# still uploads to your local server; it forwards the bytes to production, and
# the returned public_url points to production. Leave empty in production.
# REMOTE_UPLOAD_BASE=https://forly.srv1173890.hstgr.cloud

# n8n webhooks. WW1 = photos → video pipeline (the demo path).
N8N_WW1_WEBHOOK_URL=https://n8n.srv1173890.hstgr.cloud/webhook/dashboard-create
N8N_PIPELINE_WEBHOOK_URL=https://n8n.srv1173890.hstgr.cloud/webhook/property-page-builder

# Where finished landing pages are served (for the status link).
PAGE_BASE_URL=https://call4li-nadlan.web.app

# Optional: path to a Firebase service-account key to write listings to real
# Firestore (needed for the Property Page Builder step). Omit for in-memory.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# Agent auth: HMAC secret for session cookies + one-tap extend links (was
# FORLY_JWT_SECRET in the Cloud Functions path). REQUIRED for login/OTP,
# dashboard, and signup routes — without it those endpoints return 503.
# Use a long random value (e.g. `openssl rand -hex 32`). Keep it stable, and
# identical to the Functions secret if both paths must accept each other's cookies.
# FORLY_JWT_SECRET=

# WhatsApp (Green-API) — REQUIRED for OTP delivery and agent/lead notifications.
# GREENAPI_INSTANCE=
# GREENAPI_TOKEN=

# n8n Leads Handler webhook (prospect funnel). Optional.
# N8N_LEAD_WEBHOOK_URL=

# Room-name labels on /api/video-overlay (optional). When set and the caller
# passes `rooms`, sampled frames of the finished video are classified with a
# Claude vision call and the Hebrew room name is burned onto the segments
# where that room is on screen. Unset = titles only, no vision call.
# ANTHROPIC_API_KEY=
# OVERLAY_VISION_MODEL=claude-haiku-4-5-20251001
